{
  "name": "gated-docs",
  "version": "1.0.0",
  "description": "Local tool for accessing auth-gated sources (Google Drive, Notion, Slack) from Claude Code",
  "type": "module",
  "bin": {
    "gated-docs": "./bin/gated-docs.ts"
  },
  "scripts": {
    "dev": "node --experimental-strip-types bin/mcp-server.ts",
    "build": "tsc",
    "postinstall": "echo 'Run: gated-docs setup'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "googleapis": "^148.0.0",
    "input": "^1.0.1",
    "telegram": "^2.26.22",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "@notionhq/client": "^2.3.0",
    "@slack/web-api": "^7.9.1"
  },
  "engines": {
    "node": ">=22"
  }
}
